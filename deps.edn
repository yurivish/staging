;; Commands:
;;   clojure -M:dev                    — start the REPL (dev alias)
;;   clojure -M:run                    — run the server entrypoint
;;   clojure -X:test                   — run the tests
;;   clojure -M:outdated               — list outdated deps (via antq)
;;   clojure -M:outdated --upgrade     — upgrade outdated deps in place
{:paths ["src" "resources"]
 :deps  {org.clojure/clojure       {:mvn/version "1.12.4"}
         org.clojure/core.async    {:mvn/version "1.10.870-alpha2"}
         ;; 2.8.x has a regression (#578/#579) where on-close never fires on client
         ;; disconnect — the fix (76b869f) only landed in the 2.9 line.
         http-kit/http-kit         {:mvn/version "2.9.0-beta3"}
         org.clojure/data.json     {:mvn/version "2.5.2"}
         hiccup/hiccup             {:mvn/version "2.0.0"}
         metosin/malli             {:mvn/version "0.20.1"}
         metosin/reitit            {:mvn/version "0.10.1"}
         metosin/ring-http-response {:mvn/version "0.9.5"}
         ring/ring-core             {:mvn/version "1.15.4"}
         ring/ring-anti-forgery     {:mvn/version "1.4.0"}
         com.stuartsierra/component {:mvn/version "1.2.0"}
         com.stuartsierra/dependency {:mvn/version "1.0.0"}
         com.aayushatharva.brotli4j/brotli4j
         {:mvn/version "1.22.0"}
         ;; lmdbjava bundles native libs for linux/mac/windows; no JNI
         ;; compile on our end. Needs --add-opens JVM flags (below) on
         ;; JDK 16+ so it can reflect into DirectByteBuffer internals.
         org.lmdbjava/lmdbjava     {:mvn/version "0.9.3"}
         com.github.seancorfield/next.jdbc {:mvn/version "1.3.1093"}
         com.github.seancorfield/honeysql  {:mvn/version "2.7.1368"}
         org.xerial/sqlite-jdbc            {:mvn/version "3.53.0.0"}
         ;; tech.ml.dataset for parquet/arrow/csv. The parquet path pulls in
         ;; hadoop; exclusions follow the set documented at
         ;; techascent.github.io/tech.ml.dataset/tech.v3.libs.parquet.html
         ;; (jetty/jersey/log4j/kerby/zookeeper/... — unused server-side bits
         ;; that also ship CVEs).
         techascent/tech.ml.dataset       {:mvn/version "7.066"}
         org.apache.parquet/parquet-hadoop {:mvn/version "1.12.0"
                                            :exclusions [org.slf4j/slf4j-log4j12]}
         org.apache.hadoop/hadoop-common   {:mvn/version "3.3.0"
                                            :exclusions [com.sun.jersey/jersey-core
                                                         com.sun.jersey/jersey-json
                                                         com.sun.jersey/jersey-server
                                                         com.sun.jersey/jersey-servlet
                                                         dnsjava/dnsjava
                                                         org.eclipse.jetty/jetty-server
                                                         org.eclipse.jetty/jetty-servlet
                                                         org.eclipse.jetty/jetty-util
                                                         org.eclipse.jetty/jetty-webapp
                                                         javax.activation/javax.activation-api
                                                         javax.servlet.jsp/jsp-api
                                                         javax.servlet/javax.servlet-api
                                                         io.netty/netty-codec
                                                         io.netty/netty-handler
                                                         io.netty/netty-transport
                                                         io.netty/netty-transport-native-epoll
                                                         org.codehaus.jettison/jettison
                                                         org.apache.zookeeper/zookeeper
                                                         org.apache.curator/curator-recipes
                                                         org.apache.curator/curator-client
                                                         org.apache.htrace/htrace-core4
                                                         org.apache.hadoop.thirdparty/hadoop-shaded-protobuf_3_7
                                                         org.apache.hadoop/hadoop-auth
                                                         org.apache.kerby/kerb-core
                                                         commons-cli/commons-cli
                                                         commons-net/commons-net
                                                         org.apache.commons/commons-lang3
                                                         org.apache.commons/commons-text
                                                         org.apache.commons/commons-configuration2
                                                         com.google.re2j/re2j
                                                         com.google.code.findbugs/jsr305
                                                         com.jcraft/jsch
                                                         log4j/log4j
                                                         org.slf4j/slf4j-log4j12]}
         dev.langchain4j/langchain4j                  {:mvn/version "1.13.0"}
         dev.langchain4j/langchain4j-anthropic        {:mvn/version "1.13.0"}
         dev.langchain4j/langchain4j-open-ai          {:mvn/version "1.13.0"}
         ;; Gemini via Google AI Studio (API-key auth). For GCP/Vertex
         ;; auth use `langchain4j-vertex-ai-gemini` instead.
         dev.langchain4j/langchain4j-google-ai-gemini {:mvn/version "1.13.0"}
         ;; SLF4J provider. Silences the "No SLF4J providers were found"
         ;; warning that langchain4j (and other transitive users) trigger.
         ;; `slf4j-nop` discards all log output; swap it for
         ;;   ch.qos.logback/logback-classic — full-featured, configurable
         ;;   org.slf4j/slf4j-simple         — minimal stderr logger
         ;; if you want actual log output.
         org.slf4j/slf4j-nop                   {:mvn/version "2.0.17"}
         babashka/process                      {:mvn/version "0.6.25"}}
 ;; brotli4j calls System.loadLibrary, which trips JDK 24+ restricted-method warnings.
 ;; Granting native access to the unnamed module silences them.
 ;;
 ;; --add-opens for java.nio/sun.nio.ch is required by lmdbjava; without it,
 ;; the first ByteBuffer op throws InaccessibleObjectException.
 :aliases
 {:run  {:jvm-opts  ["--enable-native-access=ALL-UNNAMED"
                     "--add-opens=java.base/java.nio=ALL-UNNAMED"
                     "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"]
         :main-opts ["-e" "(do (set! *warn-on-reflection* true) nil)"
                     "-m" "demo.server"]}
  :dev  {:extra-paths ["dev"]
         :jvm-opts    ["--enable-native-access=ALL-UNNAMED"
                       "--add-opens=java.base/java.nio=ALL-UNNAMED"
                       "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"]
         :extra-deps  {org.clojure/tools.namespace {:mvn/version "1.5.1"}
                       org.clojure/test.check      {:mvn/version "1.1.3"}}
         :main-opts   ["-e" "(user/start!)" "-r"]}
  ;; Default suite excludes ^:costly tests (real-API calls that burn tokens)
  ;; and ^:slow tests (multi-second fuzz/property runs). Run `clojure
  ;; -X:test-costly` for the costly suite; `clojure -X:test-slow` for slow.
  :test {:extra-deps {org.clojure/test.check            {:mvn/version "1.1.3"}
                      io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :jvm-opts   ["--add-opens=java.base/java.nio=ALL-UNNAMED"
                      "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"]
         :exec-fn    toolkit.test-runner/test
         :exec-args  {:dirs ["src"] :patterns [".*-test$"] :excludes [:costly :slow]}}
  :test-costly {:extra-deps {org.clojure/test.check            {:mvn/version "1.1.3"}
                             io.github.cognitect-labs/test-runner
                             {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
                :jvm-opts   ["--add-opens=java.base/java.nio=ALL-UNNAMED"
                             "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"
                             ;; Belt + suspenders: costly tests also check for this sys-prop, so
                             ;; REPL/IDE invocations that bypass the :includes filter still skip.
                             "-Dtest.costly=1"]
                :exec-fn    toolkit.test-runner/test
                :exec-args  {:dirs ["src"] :patterns [".*-test$"] :includes [:costly]}}
  :test-slow   {:extra-deps {org.clojure/test.check            {:mvn/version "1.1.3"}
                             io.github.cognitect-labs/test-runner
                             {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
                :jvm-opts   ["--add-opens=java.base/java.nio=ALL-UNNAMED"
                             "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"]
                :exec-fn    toolkit.test-runner/test
                :exec-args  {:dirs ["src"] :patterns [".*-test$"] :includes [:slow]}}
  ;; Benchmarks (criterium). Kept on a separate :bench classpath so prod
  ;; and :test dep graphs are unchanged.
  ;;   clojure -M:bench           — full suite
  ;;   clojure -M:bench stree     — stree scenarios only
  ;;   clojure -M:bench sublist   — sublist scenarios only
  :bench {:extra-paths ["bench"]
          :extra-deps  {criterium/criterium {:mvn/version "0.4.6"}}
          :jvm-opts    ["--add-opens=java.base/java.nio=ALL-UNNAMED"
                        "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"]
          :main-opts   ["-m" "toolkit.bench"]}
  :rebel {:extra-deps {com.bhauman/rebel-readline {:mvn/version "0.1.7"}}
          :main-opts  ["-m" "rebel-readline.main"]}
  ;; Podcast extraction pipeline. Carries the lmdbjava add-opens because
  ;; toolkit.llm.cache opens an LMDB env. Use as:
  ;;   clojure -M:podcast -e '(require (quote podcast.core)) (podcast.core/extract! ...)'
  ;;   clojure -M:podcast -m podcast.core sentiment stumpf.json out/sentiment.json
  :podcast {:jvm-opts ["--add-opens=java.base/java.nio=ALL-UNNAMED"
                       "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"]}
  ;; Check for outdated deps: clojure -M:outdated
  ;; Upgrade in place:        clojure -M:outdated --upgrade
  :outdated {:deps      {com.github.liquidz/antq {:mvn/version "RELEASE"}
                         org.slf4j/slf4j-nop     {:mvn/version "2.0.17"}}
             :main-opts ["-m" "antq.core"]}
  ;; Lint: clojure -M:kondo --lint src
  :kondo {:deps      {clj-kondo/clj-kondo {:mvn/version "2026.04.15"}}
          :main-opts ["-m" "clj-kondo.main"]}}}
